#include <WiFi.h>
#include <WebServer.h>
#include <ESP32Servo.h>

// --- Configuration ---
const char* ssid = "Robot_AP";
const char* password = "password123";

// Pin Definitions (Matches previous diagram)
const int ENA = 33, IN1 = 14, IN2 = 27, IN3 = 26, IN4 = 25, ENB = 32;
const int pinBase = 13, pinArm = 12, pinGripper = 4;

Servo sBase, sArm, sGripper;
WebServer server(80);

// HTML Webpage (Simplified for Mobile)
const char* htmlPage = R"rawliteral(
<!DOCTYPE html><html><head><meta name="viewport" content="width=device-width, initial-scale=1">
<style>
  .btn { background: #4CAF50; border: none; color: white; padding: 20px; text-align: center; 
         display: inline-block; font-size: 18px; margin: 5px; width: 100px; border-radius: 10px;}
  .grid { display: grid; grid-template-columns: auto auto auto; justify-content: center; }
</style></head>
<body>
  <h2 style="text-align:center">ESP32 Robot Control</h2>
  <div style="text-align:center">
    <img src="http://192.168.1.XX:81/stream" style="width:100%; max-width:400px; border:2px solid #333;"><br>
    
    <div class="grid">
      <div></div><button class="btn" onclick="fetch('/F')">UP</button><div></div>
      <button class="btn" onclick="fetch('/L')">LEFT</button>
      <button class="btn" onclick="fetch('/S')">STOP</button>
      <button class="btn" onclick="fetch('/R')">RIGHT</button>
      <div></div><button class="btn" onclick="fetch('/B')">DOWN</button><div></div>
    </div>
    <h3>Arm Controls</h3>
    <button class="btn" onclick="fetch('/grab')">GRAB</button>
    <button class="btn" onclick="fetch('/release')">RELEASE</button>
  </div>
</body></html>)rawliteral";

void handleRoot() { server.send(200, "text/html", htmlPage); }

// --- Motor Logic ---
void motor(int s1, int s2, int s3, int s4) {
  digitalWrite(IN1, s1); digitalWrite(IN2, s2);
  digitalWrite(IN3, s3); digitalWrite(IN4, s4);
  ledcWrite(0, 200); ledcWrite(1, 200); // Speed set to 200/255
}

void setup() {
  Serial.begin(115200);
  pinMode(IN1, OUTPUT); pinMode(IN2, OUTPUT); pinMode(IN3, OUTPUT); pinMode(IN4, OUTPUT);
  ledcSetup(0, 5000, 8); ledcSetup(1, 5000, 8);
  ledcAttachPin(ENA, 0); ledcAttachPin(ENB, 1);
  
  sBase.attach(pinBase); sArm.attach(pinArm); sGripper.attach(pinGripper);

  WiFi.softAP(ssid, password);
  Serial.println("Access Point Started");
  Serial.print("IP Address: "); Serial.println(WiFi.softAPIP());

  // Define Web Routes
  server.on("/", handleRoot);
  server.on("/F", []() { motor(1,0,1,0); server.send(200); });
  server.on("/B", []() { motor(0,1,0,1); server.send(200); });
  server.on("/L", []() { motor(0,1,1,0); server.send(200); });
  server.on("/R", []() { motor(1,0,0,1); server.send(200); });
  server.on("/S", []() { motor(0,0,0,0); server.send(200); });
  server.on("/grab", []() { sGripper.write(90); server.send(200); });
  server.on("/release", []() { sGripper.write(0); server.send(200); });

  server.begin();
}

void loop() {
  server.handleClient();
}
